{
  "name": "Employment",
  "slug": "employment",
  "version": "1.0.0",
  "description": "Get a job and earn a steady income",
  "author": "OpenPBBG",
  "enabled": true,
  "requires": {
    "laravel": "^11.0",
    "plugins": {}
  },
  "settings": {
    "icon": "💼",
    "color": "yellow",
    "route": "employment.index",
    "menu": {
      "enabled": true,
      "order": 10,
      "section": "activities",
      "parent": null
    },
    "permissions": {
      "view": "level:1",
      "apply": "level:1",
      "work": "level:1"
    },
