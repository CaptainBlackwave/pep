{
    "name": "Jail",
    "slug": "jail",
    "version": "4.0.0",
    "description": "View jailed players and attempt bust outs or pay bail",
    "author": "OpenPBBG",
    "enabled": true,
    "license_required": false,
    "requires": {
        "laravel": "^11.0",
        "plugins": {}
    },
    "settings": {
        "icon": "⛓️",
        "color": "gray",
        "route": "jail.index",
        "menu": {
            "enabled": true,
            "order": 6,
            "section": "actions",
            "parent": null
        }
    },
    "hooks": {
        "user.jailed": true,
        "user.released": true,
        "customMenus": true
    },
    "routes": {
        "web": true,
        "api": true,
        "admin": true
    },
    "frontend": {
        "slots": {
            "sidebar-widget": ["JailWidget.vue"]
        }
    }
}
